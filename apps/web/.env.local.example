# Anthropic Claude API (para SOCIO chat, generate-plan, snap-eat)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Clerk Auth (https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Postgres connection string — usa la "Transaction pooler" de Supabase
# (Settings → Database → Connection string → URI, modo "Transaction")
DATABASE_URL=postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase (solo si usas el cliente JS directamente; no necesario para los API routes)
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
